<% layout("/layouts/boilerplate") %>
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #fe424d 0%, #ff6b6b 100%);
        --success-gradient: linear-gradient(135deg, #22c55e 0%, #10b981 100%);
        --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        --info-gradient: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    body {
        background-color: #f8fafc;
    }

    .admin-header {
        background: white;
        padding: 2rem 0;
        margin-bottom: 2rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .stat-card {
        border: none;
        border-radius: 20px;
        color: white;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        position: relative;
    }

    .stat-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .stat-card::before {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: rgba(255, 255, 255, 0.1);
        transform: rotate(45deg);
        pointer-events: none;
    }

    .bg-grad-primary { background: var(--primary-gradient); }
    .bg-grad-success { background: var(--success-gradient); }
    .bg-grad-warning { background: var(--warning-gradient); }
    .bg-grad-info { background: var(--info-gradient); }

    .stat-icon {
        font-size: 3rem;
        opacity: 0.3;
        position: absolute;
        right: 20px;
        bottom: 20px;
    }

    .stat-number {
        font-size: 3rem;
        font-weight: 800;
        margin: 0;
    }

    .stat-label {
        font-size: 1.1rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.9;
    }

    .dashboard-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        background: white;
    }

    .card-header-custom {
        background: white;
        border-bottom: 1px solid #f1f5f9;
        padding: 1.5rem;
        border-radius: 20px 20px 0 0 !important;
    }

    .activity-item {
        padding: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s;
    }

    .activity-item:hover {
        background: #f8fafc;
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .btn-view-all {
        border-radius: 10px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .admin-tag {
        background: #fee2e2;
        color: #ef4444;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
    }
</style>

<div class="admin-header shadow-sm">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="fw-bold text-dark mb-1">Control Center</h1>
                <p class="text-muted mb-0">Overview of Wanderlust platform performance and activity.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="btn-group">
                    <a href="/admin/users" class="btn btn-outline-danger btn-view-all me-2">Manage Users</a>
                    <a href="/admin/listings" class="btn btn-outline-success btn-view-all me-2">Manage Listings</a>
                    <a href="/admin/bookings" class="btn btn-danger btn-view-all">Manage Bookings</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <!-- Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card stat-card bg-grad-primary p-4">
                <div class="position-relative z-1">
                    <p class="stat-label">Total Users</p>
                    <h2 class="stat-number"><%= totalUsers %></h2>
                </div>
                <i class="fa-solid fa-users stat-icon"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-grad-success p-4">
                <div class="position-relative z-1">
                    <p class="stat-label">Active Lodges</p>
                    <h2 class="stat-number"><%= totalListings %></h2>
                </div>
                <i class="fa-solid fa-house-chimney stat-icon"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-grad-warning p-4">
                <div class="position-relative z-1">
                    <p class="stat-label">Total Reviews</p>
                    <h2 class="stat-number"><%= totalReviews %></h2>
                </div>
                <i class="fa-solid fa-star stat-icon"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-grad-info p-4">
                <div class="position-relative z-1">
                    <p class="stat-label">Total Bookings</p>
                    <h2 class="stat-number"><%= totalBookings %></h2>
                </div>
                <i class="fa-solid fa-calendar-check stat-icon"></i>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Users -->
        <div class="col-lg-6">
            <div class="card dashboard-card h-100">
                <div class="card-header-custom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Recent Signups</h5>
                    <a href="/admin/users" class="btn btn-sm btn-light text-danger fw-bold">View All</a>
                </div>
                <div class="card-body p-0">
                    <% for(let user of recentUsers) { %>
                        <div class="activity-item d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fa-solid fa-user text-danger"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="mb-0 fw-bold">@<%= user.username %></h6>
                                <small class="text-muted"><%= user.email %></small>
                            </div>
                            <div>
                                <span class="<%= user.role === 'admin' ? 'admin-tag' : 'badge bg-light text-dark rounded-pill' %>">
                                    <%= user.role %>
                                </span>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Recent Listings -->
        <div class="col-lg-6">
            <div class="card dashboard-card h-100">
                <div class="card-header-custom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Latest Listings</h5>
                    <a href="/admin/listings" class="btn btn-sm btn-light text-danger fw-bold">Manage All</a>
                </div>
                <div class="card-body p-0">
                    <% for(let listing of recentListings) { %>
                        <div class="activity-item d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <% if(listing.image && listing.image.length > 0) { %>
                                    <img src="<%= listing.image[0].url %>" class="rounded-3" style="width: 50px; height: 50px; object-fit: cover;" alt="">
                                <% } else { %>
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-image text-muted"></i>
                                    </div>
                                <% } %>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="mb-0 fw-bold"><%= listing.title %></h6>
                                <small class="text-muted"><%= listing.location %></small>
                            </div>
                            <div class="text-end">
                                <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-dark rounded-pill">View</a>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

