<% layout("/layouts/boilerplate") -%>

<style>
    .profile-container {
        max-width: 900px;
        margin: 2rem auto;
        padding: 2rem;
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #eee;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #fe424d, #ff5a5f);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: white;
        font-weight: bold;
    }

    .profile-info h2 {
        margin: 0;
        font-weight: 700;
        color: #333;
    }

    .profile-info p {
        margin: 5px 0;
        color: #666;
    }

    .logout-btn {
        margin-top: 10px;
        background-color: #fe424d !important;
        border: none !important;
        padding: 8px 20px !important;
        border-radius: 8px !important;
        transition: all 0.3s ease !important;
    }

    .logout-btn:hover {
        background-color: #e03a44 !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(254, 66, 77, 0.3);
    }

    .user-listings-section {
        margin-top: 3rem;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        position: relative;
        display: inline-block;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 40px;
        height: 3px;
        background: #fe424d;
        border-radius: 2px;
    }

    .listing-link {
        text-decoration: none;
        color: inherit;
    }

    .listing-card {
        border: none !important;
        margin-bottom: 2rem;
        transition: transform 0.3s ease;
    }

    .listing-card:hover {
        transform: translateY(-5px);
    }

    .main-card {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        background: #fff;
    }

    .card-img-top {
        height: 14rem;
        object-fit: cover;
    }

    .card-body {
        padding: 1.2rem !important;
    }

    .btn-outline-dark, .btn-outline-danger {
        border-radius: 6px !important;
        font-size: 0.85rem !important;
        padding: 5px 12px !important;
    }

    @media (max-width: 576px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }
        
        .profile-container {
            padding: 1.5rem;
            margin: 1rem;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">
            <% if (currUser.image && currUser.image.url) { %>
                <img src="<%= currUser.image.url %>" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
            <% } else { %>
                <%= currUser.username.charAt(0).toUpperCase() %>
            <% } %>
        </div>
        <div class="profile-info">
            <h2><%= currUser.username %></h2>
            <p><i class="fa-regular fa-envelope me-2"></i><%= currUser.email %></p>
            <a href="/logout" class="btn btn-danger logout-btn">
                <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
            </a>
        </div>
    </div>

    <div class="user-listings-section">
        <h3 class="section-title">Your Listings</h3>
        
        <% if (allListings && allListings.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
                <% for(let listing of allListings) { %>
                    <div class="card col listing-card">
                        <div class="main-card position-relative">
                            <a href="/listings/<%= listing._id %>" class="stretched-link"></a>
                            <% let imgUrl='/images/default.jpg' ; 
                               if (Array.isArray(listing.image) && listing.image.length > 0) {
                                   imgUrl = listing.image[0].url;
                               } else if (listing.image && listing.image.url) {
                                   imgUrl = listing.image.url;
                               }
                            %>
                            <img src="<%= imgUrl %>" class="card-img-top" alt="Listing Image">
                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b><br>
                                    &#8377; <%= listing.price.toLocaleString("en-IN") %> / Night
                                </p>
                                <div class="d-flex justify-content-between mt-2" style="position: relative; z-index: 10;">
                                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-dark">
                                        <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                                    </a>
                                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">You haven't created any listings yet.</p>
                <a href="/listings/new" class="btn btn-outline-danger">Create Your First Listing</a>
            </div>
        <% } %>
    </div>

    <div class="user-listings-section mt-5">
        <h3 class="section-title">My Bookings</h3>
        <% if (bookings && bookings.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
                <% for(let booking of bookings) { %>
                    <div class="card col listing-card">
                        <div class="main-card position-relative">
                            <a href="/listings/<%= booking.listing._id %>" class="stretched-link"></a>
                            <img src="<%= booking.listing.image?.[0]?.url || booking.listing.image?.url || '/images/default.jpg' %>" class="card-img-top" alt="Listing Image">
                            <div class="card-body">
                                <p class="card-text">
                                    <span class="badge <%= booking.status === 'Cancelled' ? 'bg-secondary' : 'bg-success' %> mb-2"><%= booking.status %></span><br>
                                    <b><%= booking.listing.title %></b><br>
                                    <small class="text-muted">
                                        <b>Duration:</b> <%= booking.checkIn.toDateString() %> - <%= booking.checkOut.toDateString() %>
                                    </small><br>
                                    <small class="text-muted">
                                        <b>Booked on:</b> <%= booking.createdAt ? booking.createdAt.toLocaleString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'N/A' %>
                                    </small><br>
                                    <strong class="text-danger">Total: &#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></strong>
                                </p>
                                <div class="d-flex gap-2 mt-2" style="position: relative; z-index: 10;">
                                    <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-outline-danger flex-grow-1">View Lodge</a>
                                    <% if (booking.status !== 'Cancelled' && new Date(booking.checkIn) > new Date()) { %>
                                        <form action="/listings/<%= booking.listing._id %>/bookings/<%= booking._id %>/cancel" method="POST" class="d-inline flex-grow-1 m-0" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                            <button class="btn btn-sm btn-outline-danger w-100">Cancel</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">You have no upcoming bookings.</p>
                <a href="/listings" class="btn btn-outline-danger">Book Your Next Adventure</a>
            </div>
        <% } %>
    </div>

    <div class="user-listings-section mt-5">
        <h3 class="section-title">Your Wishlist</h3>
        <% if (wishlist && wishlist.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
                <% for(let listing of wishlist) { %>
                    <div class="card col listing-card">
                        <div class="main-card position-relative">
                            <a href="/listings/<%= listing._id %>" class="stretched-link"></a>
                            <% let imgUrl='/images/default.jpg' ; 
                               if (Array.isArray(listing.image) && listing.image.length > 0) {
                                   imgUrl = listing.image[0].url;
                               } else if (listing.image && listing.image.url) {
                                   imgUrl = listing.image.url;
                               }
                            %>
                            <img src="<%= imgUrl %>" class="card-img-top" alt="Listing Image">
                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b><br>
                                    &#8377; <%= listing.price.toLocaleString("en-IN") %> / Night
                                </p>
                                <a href="/wishlist/<%= listing._id %>" class="btn btn-sm btn-outline-danger w-100 mt-2" style="position: relative; z-index: 10;">
                                    <i class="fa-solid fa-heart-broken me-1"></i>Remove from Wishlist
                                </a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">Your wishlist is empty.</p>
                <a href="/listings" class="btn btn-outline-danger">Explore More Lodges</a>
            </div>
        <% } %>
    </div>
</div>
