    <style>
        .tax-info {
            display: none;
        }


        .cardd-body {
            position: relative;
            overflow: hidden;
            /* Ensures content does not overflow */
            word-wrap: break-word;
            /* Ensures text wraps properly */
        }

        .starabilityy-result {
            white-space: nowrap;
            /* Prevents text from breaking into new lines */
            overflow: hidden;
            text-overflow: ellipsis;
            /* Adds "..." if content overflows */
            display: flex;
            /* Ensures proper star alignment */
            flex-wrap: wrap;
            /* Allows stars to wrap within the container */
            justify-content: center;
            /* Centers stars within the card */
            max-width: 100%;
            /* Ensures stars stay inside the box */
        }

        .cardd {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            margin: auto;
            padding: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        /* main card hover effect */
        .main-card {
            /* border: 2px solid black; */
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
            transition: box-shadow 0.3s ease-in-out;
            padding: 15px;
            margin-bottom: 2rem;

        }

        .main-card:hover {
            box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.8);
        }

        @media (max-width: 576px) {
            .cardd {
                max-width: 90%;
                /* Adjusts width for smaller screens */
            }

            .starabilityy-result {
                font-size: 0.9rem;
                /* Adjusts size to prevent overflow */
            }
        }

        /* Payment Modal CSS Customizations */
        .nav-pills .nav-link {
            color: #6c757d;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            transition: all 0.2s ease-in-out;
        }

        .nav-pills .nav-link.active {
            color: #fff !important;
            background: #fe424d !important;
            border-color: #fe424d !important;
            box-shadow: 0 4px 10px rgba(254, 66, 77, 0.2);
        }
        
        .tracking-wide {
            letter-spacing: 0.1rem;
        }
    </style>
    <div class="row mt-3">
