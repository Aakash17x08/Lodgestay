            <h4 class="fw-bold mb-3"><i class="fa-solid fa-map-location-dot me-2 text-danger"></i>Where you'll be</h4>
            <div id="map" style="height: 380px; width: 100%; border-radius: 15px; border: 1px solid #dee2e6; box-shadow: 0 4px 15px rgba(0,0,0,0.05); z-index: 1;"></div>
        </div>

        <script>
            // Leaflet Map Initialization with Dynamic Nominatim Geocoding
            document.addEventListener("DOMContentLoaded", function() {
                const location = "<%= listing.location %>";
                const country = "<%= listing.country %>";
                const title = "<%= listing.title %>";
                
                // Default coordinates (New Delhi) in case geocoding fails
                let defaultLat = 28.6139;
                let defaultLng = 77.2090;
                
                const map = L.map('map').setView([defaultLat, defaultLng], 12);
                
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© OpenStreetMap contributors'
                }).addTo(map);
                
                const query = encodeURIComponent(`${location}, ${country}`);
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${query}&limit=1`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            const lat = parseFloat(data[0].lat);
                            const lon = parseFloat(data[0].lon);
                            map.setView([lat, lon], 13);
                            
                            const marker = L.marker([lat, lon]).addTo(map);
                            marker.bindPopup(`<b>${title}</b><br>${location}, ${country}`).openPopup();
                        } else {
                            const marker = L.marker([defaultLat, defaultLng]).addTo(map);
                            marker.bindPopup(`<b>${location}</b><br>Coordinates could not be determined.`).openPopup();
                        }
                    })
                    .catch(err => {
                        console.error("Geocoding failed:", err);
                        const marker = L.marker([defaultLat, defaultLng]).addTo(map);
                        marker.bindPopup(`<b>${location}</b><br>Failed to geocode location.`).openPopup();
                    });
            });
        </script>

